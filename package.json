{
  "name": "bastion-cc",
  "version": "2.0.0",
  "description": "Fortified dev stack for Claude Code — one command to install ECC, GSD, Ralph Loop, and safety hooks",
  "main": "bin/bastion.cjs",
  "bin": {
    "bastion": "bin/bastion.cjs"
  },
  "files": [
    "bin/",
    "commands/",
    "hooks/"
  ],
  "scripts": {
    "install-local": "node bin/bastion.cjs install",
    "uninstall-local": "node bin/bastion.cjs uninstall",
    "test": "node bin/bastion.cjs detect"
  },
  "keywords": [
    "claude-code",
    "bastion",
    "dev-stack",
    "code-quality",
    "secret-detection",
    "migration-safety"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
